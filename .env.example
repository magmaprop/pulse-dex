# Wallet Connect - Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# RPC Endpoints - Get from https://www.alchemy.com or https://www.quicknode.com
NEXT_PUBLIC_ALCHEMY_KEY=your_alchemy_key
NEXT_PUBLIC_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/your_key
NEXT_PUBLIC_RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your_key
NEXT_PUBLIC_RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/your_key

# Pyth Network Hermes (free, no key needed for public endpoint)
NEXT_PUBLIC_PYTH_HERMES_URL=https://hermes.pyth.network

# Enable testnets for development
NEXT_PUBLIC_ENABLE_TESTNETS=true

# Your deployed contract addresses (fill after deployment)
NEXT_PUBLIC_VAULT_CONTRACT=
NEXT_PUBLIC_TRADING_CONTRACT=
